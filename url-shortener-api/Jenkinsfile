pipeline {
    agent any

    environment {
        DEPLOY_PATH = '/home/ubuntu/workdir/devops-practice-apps/url-shortener-api'
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Install Dependencies') {
            steps {
                dir('url-shortener-api') {
                    sh 'npm install'
                }
            }
        }

        stage('Build') {
            steps {
                dir('url-shortener-api') {
                    sh 'npm run build'
                }
            }
        }

        stage('Copy Static Files') {
            steps {
                dir('url-shortener-api') {
                    sh 'rm -rf dist/public && cp -r src/public dist/'
                }
            }
        }

        stage('Deploy Files') {
            steps {
                sh '''
                    rsync -av --delete url-shortener-api/dist/ ${DEPLOY_PATH}/dist/
                    rsync -av url-shortener-api/package.json ${DEPLOY_PATH}/
                    rsync -av url-shortener-api/src/public/ ${DEPLOY_PATH}/src/public/
                '''
            }
        }

        stage('Restart Service') {
            steps {
                sh 'sudo systemctl restart url-shortener-api'
            }
        }

        stage('Verify Service') {
            steps {
                sh 'sudo systemctl status url-shortener-api --no-pager'
            }
        }
    }
}
